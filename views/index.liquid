{% include 'partials/head.liquid' %}

<div class="ribbon-container">
  <img src="/assets/images/ribbon.svg" alt="">
  <div class="ribbon-line"></div>
</div>

<section class="gifts-overview">
  {% for product in products %}
    {% if product.amount != "0.00" %}
      <article class="gift">
        <button class="save-button"><img src="/assets/images/black-save-icon.svg" alt=""></button>
        <a href="/gift/{{ product.slug }}">
          <img class="product-image" src="{{ product.image }}" alt="">
          <h3 class="product-name">{{ product.name }}</h3>
          <p class="product-price">€{{ product.amount }}</p>
        </a>
      </article>
    {% endif %}
  {% endfor %}
</section>

<aside class="chatbot">
  <div class="input-container">
    <button class="mic-button"><img src="/assets/images/mic-icon.svg" alt=""></button>
    <input type="text" placeholder="Type your message...">
    <button class="search-button"><img src="/assets/images/search-icon.svg" alt=""></button>
  <div>
</aside>

{% include 'partials/foot.liquid' %}
